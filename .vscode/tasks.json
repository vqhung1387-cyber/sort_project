{
 "version": "2.0.0",
 "tasks": [
  {
   "label": "build cpp project",
   "type": "shell",
   "command": "g++",
   "args": [
    "-g",
    "source/*.cpp",
    "-Iinclude",
    "-o",
    "main.exe"
   ],
   "options": {
    "cwd": "${workspaceFolder}"
   },
   "group": {
    "kind": "build",
    "isDefault": true
   },
   "problemMatcher": ["$gcc"]
  }
 ]
}